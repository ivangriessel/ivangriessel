---
layout: base.njk
---

<article class="max-w-4xl mx-auto px-5 md:px-10">

  {# ── Page header ─────────────────────────────────────────────────── #}
  <header class="py-16 border-b border-black/10">
    <a href="/#work" class="inline-flex items-center gap-2 font-inter text-sm font-medium text-muted hover:text-black transition-colors mb-8">
      ← Back to work
    </a>
    <h1 class="font-avenir font-bold text-4xl md:text-5xl lg:text-6xl leading-tight max-w-4xl">
      {{ title }}
    </h1>
  </header>

  {# ── Outcomes ────────────────────────────────────────────────────── #}
  {% if outcomes %}
  <section class="py-14 border-b border-black/10">
    <h2 class="font-avenir font-bold text-3xl mb-8">Outcomes.</h2>
    <ul class="flex flex-col gap-4 max-w-2xl">
      {% for outcome in outcomes %}
      <li class="flex gap-4 items-start">
        <span class="mt-1.5 shrink-0 w-2.5 h-2.5 rounded-full bg-yellow border-2 border-black"></span>
        <p class="font-inter text-lg leading-relaxed">{{ outcome }}</p>
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {# ── Problem ─────────────────────────────────────────────────────── #}
  {% if problem %}
  <section class="py-14 border-b border-black/10">
    <h2 class="font-avenir font-bold text-3xl mb-6">Problem.</h2>
    <p class="font-inter text-lg text-muted leading-relaxed max-w-2xl">{{ problem }}</p>
  </section>
  {% endif %}

  {# ── What I did ──────────────────────────────────────────────────── #}
  <section class="py-14 border-b border-black/10">
    <h2 class="font-avenir font-bold text-3xl mb-10">What I did.</h2>
    <div class="flex flex-col gap-16">
      {{ content | safe }}
    </div>
  </section>

  {# ── Learnings ───────────────────────────────────────────────────── #}
  {% if learnings %}
  <section class="py-14">
    <h2 class="font-avenir font-bold text-3xl mb-8">Learnings.</h2>
    <ul class="flex flex-col gap-4 max-w-2xl">
      {% for learning in learnings %}
      <li class="flex gap-4 items-start">
        <span class="mt-1.5 shrink-0 w-2.5 h-2.5 rounded-full border-2 border-black"></span>
        <p class="font-inter text-lg leading-relaxed text-muted">{{ learning }}</p>
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

</article>
