<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title if title else 'Ivan Griessel' }}</title>
  <meta name="description" content="{{ description if description else 'Product &amp; Design Leader. 11+ years in design, 8+ years in HealthTech.' }}" />

  <link rel="icon" href="/assets/images/favicon.ico" sizes="32x32" />
  <link rel="icon" href="/assets/images/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/assets/images/favicon.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Major+Mono+Display&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="/assets/css/eink.css" />

</head>
<body>

  <nav class="ei-nav">
    <div class="ei-nav__inner">
      <div class="ei-nav__brand">
        <span class="ei-nav__mark"></span>
        <a href="/" class="ei-nav__name">IVAN GRIESSEL</a>
      </div>
      <div class="ei-nav__links">
        <a href="/#work">/WORK</a>
        <a href="/#recommendations">/RECOMMENDATIONS</a>
        <a href="/#about">/ABOUT</a>
      </div>
    </div>
  </nav>

  <main>
    {{ content | safe }}
  </main>

  <footer class="ei-footer">
    <div class="ei-footer__inner">
      <div class="ei-rule"></div>
      <div class="ei-footer__row">
        <span class="ei-mono ei-mono--xs">© Ivan Griessel · 2026</span>
        <span class="ei-mono ei-mono--xs">Set in dot-matrix. Printed on e-paper.</span>
        <span class="ei-mono ei-mono--xs">END OF FILE</span>
      </div>
    </div>
  </footer>

  <script src="/assets/js/halftone.js"></script>
</body>
</html>
